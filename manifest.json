{
  "manifest_version": 3,
  "name": "AI Chat Printer",
  "short_name": "AI Chat Printer",
  "version": "1.5.0",
  "description": "Gemini, Claude, ChatGPT ve Grok konuşmalarını tek tıkla yazdır veya PDF olarak kaydet. Hızlı, güvenli ve ücretsiz.",
  "minimum_chrome_version": "114",
  "default_locale": "tr",
  "homepage_url": "https://github.com/baranseren/GeminiPrinter",
  "permissions": ["activeTab", "scripting", "storage", "clipboardWrite"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Chat Printer - Konuşmayı Yazdır",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["resim-yardimcilari.js", "ortak-yardimcilar.js", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["resim-yardimcilari.js", "ortak-yardimcilar.js", "content-claude.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["resim-yardimcilari.js", "ortak-yardimcilar.js", "content-chatgpt.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://grok.com/*"],
      "js": ["resim-yardimcilari.js", "ortak-yardimcilar.js", "content-grok.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "yazdir-kisayol": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Aktif AI konuşmasını yazdır"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'"
  }
}
